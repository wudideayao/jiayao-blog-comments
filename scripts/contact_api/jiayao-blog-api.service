[Unit]
Description=Jiayao Blog Contact API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/jiayao-blog/api
ExecStart=/usr/local/bin/gunicorn -w 2 -b 127.0.0.1:5001 app:app
Restart=always
RestartSec=5
EnvironmentFile=/var/www/jiayao-blog/api/.env

[Install]
WantedBy=multi-user.target
